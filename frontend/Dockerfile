# =============================================================================
# [ DOCKERFILE ARCHITECTURE & INTENT ]
#
# This Dockerfile utilizes a "Multi-Stage Build" pattern tailored for Next.js 15.
# It leverages Next.js's "standalone" output feature to create a highly
# optimized, lightweight, and secure production-ready Docker image.
#
# Why is it designed this way?
# 1. Image Size (Standalone): Next.js can trace dependencies and output only
#    the necessary files for production in the `.next/standalone` directory.
#    This drastically reduces the final image size by omitting unused node_modules.
# 2. Build Speed (Caching): By separating dependency installation (deps) from
#    the application build (builder), Docker caches the `node_modules` layer.
#    Dependencies are only re-downloaded if `package.json` changes.
# 3. Security: The application runs as a non-root user ('nextjs') following
#    the principle of least privilege.
# =============================================================================

# =============================================================================
# BASE STAGE: Common Environment Setup
# Defines the Node.js version and Alpine Linux base for all subsequent stages.
# =============================================================================
FROM node:20-alpine AS base

# =============================================================================
# 1. DEPENDENCIES STAGE: Install Application Dependencies
#    This stage is solely responsible for installing `node_modules`.
#    It caches the installation unless package files change.
# =============================================================================
FROM base AS deps
# libc6-compat is required by Alpine Linux for some native Node.js modules
# (e.g., image optimization libraries like sharp, or SWC compiler).
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy package managers' lock files and configuration
COPY package.json package-lock.json ./

# Install exact dependencies using `npm ci` (faster and more reliable than npm i)
RUN npm ci

# =============================================================================
# 2. BUILD STAGE: Compile the Next.js Application
#    This stage copies the source code and builds the production assets.
#    It relies on the `output: 'standalone'` setting in next.config.ts.
# =============================================================================
FROM base AS builder
WORKDIR /app

# Copy cached node_modules from the dependencies stage
COPY --from=deps /app/node_modules ./node_modules
# Copy the rest of the application source code
COPY . .

# Execute the Next.js build process
RUN npm run build

# =============================================================================
# 3. RUN STAGE: Production-Ready Application Execution Environment
#    This stage creates the final minimal image containing only the files
#    necessary to run the application, optimizing for size and security.
# =============================================================================
FROM base AS runner
WORKDIR /app

# Set Node environment to production
ENV NODE_ENV=production

# =============================================================================
# 3.1. Create Non-Root User
#      A non-root user and group (`nextjs`/`nodejs`) are created for enhanced
#      security, adhering to the principle of least privilege.
# =============================================================================
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# =============================================================================
# 3.2. Copy Required Files and Static Assets
#      Only the essential files generated by the standalone build are copied.
#      Ownership is transferred to the non-root user.
# =============================================================================
# Copy public directory for static assets (images, fonts, etc.)
COPY --from=builder /app/public ./public

# Copy the standalone directory (contains the actual server and node_modules subsets)
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./

# Copy static build files (JS/CSS generated by Next.js)
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# =============================================================================
# 3.3. Configure Runtime Environment
#      Switch to the non-root user, expose the port, and set environment variables.
# =============================================================================
USER nextjs

EXPOSE 3000
ENV PORT=3000
# Ensure Next.js listens on all network interfaces in the container
ENV HOSTNAME="0.0.0.0"

# =============================================================================
# 3.4. Define Application Entrypoint
#      Starts the standalone Node.js server instead of `next start`.
# =============================================================================
CMD ["node", "server.js"]
